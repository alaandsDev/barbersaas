// BarberOS — schema multi-tenant
// Cada Business é um tenant. Toda tabela "do negócio" carrega businessId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  PROFESSIONAL
}

enum Plan {
  BASIC
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INACTIVE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

// Espelha auth.users do Supabase. id = uuid do Supabase Auth.
model User {
  id          String       @id @db.Uuid
  email       String       @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  memberships Membership[]
  professional Professional?
  referralCode String?     @unique
  referredById String?     @db.Uuid
  referredBy   User?       @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]      @relation("UserReferrals")
}

model Business {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  phone         String?
  bio           String?
  brandColor    String?  // hex ex: "#f59e0b"
  coverEmoji    String?  // emoji opcional
  timezone      String   @default("America/Sao_Paulo")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscription   Subscription?
  memberships    Membership[]
  professionals  Professional[]
  services       Service[]
  customers      Customer[]
  appointments   Appointment[]
  notifications  Notification[]
}

model Notification {
  id          String    @id @default(cuid())
  businessId  String
  kind        String    // 'appointment.created' | etc
  title       String
  body        String?
  link        String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([businessId, readAt])
}

model Membership {
  id         String   @id @default(cuid())
  userId     String   @db.Uuid
  businessId String
  role       Role     @default(OWNER)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

model Subscription {
  id                   String             @id @default(cuid())
  businessId           String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 Plan               @default(BASIC)
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  business             Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Professional {
  id                 String   @id @default(cuid())
  businessId         String
  userId             String?  @unique @db.Uuid
  name               String
  bio                String?
  avatarUrl          String?
  active             Boolean  @default(true)
  commissionPercent  Int      @default(50)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  services    ProfessionalService[]
  appointments Appointment[]

  @@index([businessId])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  description     String?
  priceCents      Int
  durationMinutes Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professionals   ProfessionalService[]
  appointments    Appointment[]

  @@index([businessId])
}

model ProfessionalService {
  professionalId String
  serviceId      String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
}

model Customer {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  phone       String?
  email       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, phone])
}

model Appointment {
  id             String            @id @default(cuid())
  businessId     String
  professionalId String
  serviceId      String
  customerId     String
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(SCHEDULED)
  priceCents     Int
  notes          String?
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId, startsAt])
  @@index([professionalId, startsAt])
  @@index([startsAt, reminderSentAt])
}
